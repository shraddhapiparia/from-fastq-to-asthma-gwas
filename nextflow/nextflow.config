/*
 * Nextflow configuration — local execution only.
 *
 * No container, cluster, or cloud backend.
 * The conda environment (genomics_pipeline) must be active before running.
 */

process {
    executor = 'local'
}

// Execution reports written alongside main.nf for easy inspection.
dag {
    enabled   = true
    overwrite = true
    file      = "${projectDir}/dag.html"
}

report {
    enabled   = true
    overwrite = true
    file      = "${projectDir}/report.html"
}
